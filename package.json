{
  "name": "@use-nyte/nyte-server",
  "version": "0.0.0",
  "description": "Server code for Nyte.",
  "repository": "https://github.com/use-nyte/nyte-server",
  "license": "Apache-2.0",
  "scripts": {
    "build": "nest build",
    "coverage": "jest --coverage && open-cli coverage/lcov-report/index.html",
    "dev": "nest start --watch",
    "e2e": "jest --config tests/jest-e2e.json",
    "prepare": "husky",
    "start": "node dist/main",
    "test": "jest"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@use-nyte/eslint-config": "^1.4.1",
    "@use-nyte/prettier-config": "^1.3.3",
    "husky": "^9.1.7",
    "open-cli": "^9.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsconfig-paths": "^4.2.0",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "tests",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/../src/$1",
      "^@tests/(.*)$": "<rootDir>/../tests/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
